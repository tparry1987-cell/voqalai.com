# PostHog (free tier, EU region for GDPR)
# 1. Sign up at https://eu.posthog.com (no card required)
# 2. Create a project, copy the Project API Key from Project Settings
# 3. Copy this file to .env.local and fill in NEXT_PUBLIC_POSTHOG_KEY
# 4. Mirror these env vars in Netlify dashboard: Site settings → Environment variables
NEXT_PUBLIC_POSTHOG_KEY=phc_REPLACE_WITH_PROJECT_API_KEY
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
